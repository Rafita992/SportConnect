<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" prefHeight="450.0" prefWidth="350.0"
      stylesheets="@../css/login.css"
      styleClass="main-container"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.sportconnect.controller.LoginController">

    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>

    <Label text="SPORTCONNECT" styleClass="title-label" />

    <Label text="Bienvenido, inicia sesión" styleClass="subtitle-label" />

    <VBox spacing="10.0" styleClass="form-group">

        <Label text="Correo Electrónico" styleClass="input-label" />
        <TextField fx:id="textEmail" promptText="ejemplo@correo.com" styleClass="text-input" />

        <Label text="Contraseña" styleClass="input-label">
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </Label>
        <PasswordField fx:id="textPassword" promptText="••••••••" styleClass="text-input" />
    </VBox>

    <Button fx:id="btnLogin" maxWidth="Infinity" onAction="#handleLogin"
            text="ENTRAR" styleClass="login-button">
        <VBox.margin>
            <Insets top="10.0" />
        </VBox.margin>
    </Button>

    <Label fx:id="lblMessage" styleClass="error-label" wrapText="true" />

</VBox>