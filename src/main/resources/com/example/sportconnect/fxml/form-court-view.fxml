<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="600.0" prefWidth="1000.0"
            stylesheets="@../css/dashboard.css"
            styleClass="root-pane"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.sportconnect.controller.FormCourtController">

    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="10">
            <padding>
                <Insets top="15" bottom="15" left="30" right="30"/>
            </padding>
            <Label text="⚙" styleClass="navbar-icon"/>
            <Label text="OmniSport" styleClass="navbar-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblWelcome" styleClass="navbar-welcome"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="20">
            <padding>
                <Insets top="30" bottom="30" left="40" right="40"/>
            </padding>

            <Button text="←" styleClass="back-button" onAction="#handleBack"/>

            <VBox styleClass="table-container" spacing="15" maxWidth="500" alignment="CENTER_LEFT">
                <padding>
                    <Insets top="30" bottom="30" left="30" right="30"/>
                </padding>

                <Label fx:id="lblTitulo" text="Nueva Pista" styleClass="section-title"/>
                <Label text="Rellena los campos para gestionar la pista." styleClass="section-subtitle"/>

                <Label text="Nombre" styleClass="input-label"/>
                <TextField fx:id="txtNombre" promptText="Nombre de la pista" styleClass="text-input"/>

                <Label text="Deporte" styleClass="input-label"/>
                <ComboBox fx:id="cmbDeporte" maxWidth="Infinity" styleClass="text-input"/>

                <Label fx:id="lblMensaje" styleClass="error-label" wrapText="true"/>

                <Button fx:id="btnGuardar" text="Guardar Pista" styleClass="new-button" maxWidth="Infinity" onAction="#handleGuardar" disable="true"/>

            </VBox>
        </VBox>
    </center>

</BorderPane>
