<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            stylesheets="@../css/login.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.sportconnect.controller.RegisterController">
    <content>
        <VBox alignment="CENTER" spacing="16" prefWidth="350"
              styleClass="main-container">
            <padding>
                <Insets top="40" bottom="40" left="40" right="40"/>
            </padding>

            <Label text="SPORTCONNECT" styleClass="title-label"/>
            <Label text="Crear nueva cuenta" styleClass="subtitle-label"/>

            <VBox spacing="10" styleClass="form-group">
                <Label text="Nombre" styleClass="input-label"/>
                <TextField fx:id="txtNombre" promptText="Tu nombre" styleClass="text-input"/>

                <Label text="Apellido" styleClass="input-label"/>
                <TextField fx:id="txtApellido" promptText="Tu apellido" styleClass="text-input"/>

                <Label text="Correo Electrónico" styleClass="input-label"/>
                <TextField fx:id="txtEmail" promptText="ejemplo@correo.com" styleClass="text-input"/>

                <Label text="Teléfono" styleClass="input-label"/>
                <TextField fx:id="txtTelefono" promptText="600 000 000" styleClass="text-input"/>

                <Label text="Contraseña" styleClass="input-label"/>
                <PasswordField fx:id="txtPassword" promptText="••••••••" styleClass="text-input"/>

                <Label text="Repetir contraseña" styleClass="input-label"/>
                <PasswordField fx:id="txtPasswordConfirm" promptText="••••••••" styleClass="text-input"/>
            </VBox>

            <Button fx:id="btnRegistrar" maxWidth="Infinity" onAction="#handleRegistrar"
                    text="CREAR CUENTA" styleClass="login-button" disable="true"/>

            <Button maxWidth="Infinity" onAction="#handleVolver"
                    text="¿Ya tienes cuenta? Inicia sesión" styleClass="link-button"/>

            <Label fx:id="lblMensaje" styleClass="error-label" wrapText="true"/>
        </VBox>
    </content>
</ScrollPane>