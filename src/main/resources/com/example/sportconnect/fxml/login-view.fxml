<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" prefHeight="450.0" prefWidth="350.0"
      style="-fx-background-color: #f4f4f4; -fx-border-color: #2c3e50; -fx-border-width: 2;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.sportconnect.controller.LoginController">

    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>

    <Label text="SPORTCONNECT" textFill="#2c3e50">
        <font>
            <Font name="System Bold" size="28.0" />
        </font>
    </Label>

    <Label text="Bienvenido, inicia sesión" textFill="#7f8c8d">
        <font>
            <Font size="14.0" />
        </font>
    </Label>

    <VBox spacing="10.0">
        <Label text="Correo Electrónico" />
        <TextField fx:id="txtEmail" promptText="ejemplo@correo.com"
                   style="-fx-background-radius: 5; -fx-padding: 8;" />

        <Label text="Contraseña">
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </Label>
        <PasswordField fx:id="txtPassword" promptText="••••••••"
                       style="-fx-background-radius: 5; -fx-padding: 8;" />
    </VBox>

    <Button fx:id="btnLogin" maxWidth="Infinity" onAction="#handleLogin"
            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 5;"
            text="ENTRAR">
        <VBox.margin>
            <Insets top="10.0" />
        </VBox.margin>
        <font>
            <Font size="14.0" />
        </font>
    </Button>

    <Label fx:id="lblMessage" textFill="#e74c3c" wrapText="true" />

</VBox>